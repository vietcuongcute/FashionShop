@model IEnumerable<SanPham>
@{
    ViewData["Title"] = "Sản phẩm";
    var danhMucs = ViewBag.DanhMucs as List<DanhMuc> ?? new List<DanhMuc>();
    int? categoryId = ViewBag.CategoryId as int?;
    string keyword = ViewBag.Keyword as string ?? "";
    string sortOrder = ViewBag.SortOrder as string ?? "newest";
    decimal? minPrice = ViewBag.MinPrice as decimal?;
    decimal? maxPrice = ViewBag.MaxPrice as decimal?;
    bool? inStock = ViewBag.InStock as bool?;
}

<section class="shop-banner" style="background-image:linear-gradient(90deg, rgba(20,18,18,.72), rgba(20,18,18,.28)), url('@FashionImageHelper.GetLookbook("shop")')">
    <div class="container reveal">
        <span>VyAnhFashion Shop</span>
        <h1>A curated shop for modern dressing</h1>
        <p>Lọc nhanh theo danh mục, giá, trạng thái còn hàng và sắp xếp theo nhu cầu mua sắm. Tone giao diện và bố cục được tối ưu theo phong cách ecommerce thực tế.</p>
    </div>
</section>

<section class="container shop-layout">
    <aside class="filter-sidebar reveal">
        <div class="filter-head">
            <h2>Bộ lọc</h2>
            <a asp-controller="Product" asp-action="Index">Xóa tất cả</a>
        </div>
        <form asp-controller="Product" asp-action="Index" method="get" class="filter-form-ui">
            <label>
                <span>Từ khóa</span>
                <input type="text" name="keyword" value="@keyword" placeholder="áo sơ mi, váy, blazer..." />
            </label>
            <label>
                <span>Danh mục</span>
                <select name="categoryId">
                    <option value="">Tất cả danh mục</option>
                    @foreach (var dm in danhMucs)
                    {
                        if (categoryId == dm.Id)
                        {
                            <option value="@dm.Id" selected>@dm.TenDanhMuc</option>
                        }
                        else
                        {
                            <option value="@dm.Id">@dm.TenDanhMuc</option>
                        }
                    }
                </select>
            </label>
            <div class="price-pair">
                <label><span>Giá từ</span><input type="number" name="minPrice" value="@minPrice" min="0" placeholder="0" /></label>
                <label><span>Đến</span><input type="number" name="maxPrice" value="@maxPrice" min="0" placeholder="1000000" /></label>
            </div>
            <label>
                <span>Sắp xếp</span>
                <select name="sortOrder">
                    @if (sortOrder == "newest" || string.IsNullOrWhiteSpace(sortOrder)) { <option value="newest" selected>Mới nhất</option> } else { <option value="newest">Mới nhất</option> }
                    @if (sortOrder == "featured") { <option value="featured" selected>Nổi bật</option> } else { <option value="featured">Nổi bật</option> }
                    @if (sortOrder == "price_asc") { <option value="price_asc" selected>Giá tăng dần</option> } else { <option value="price_asc">Giá tăng dần</option> }
                    @if (sortOrder == "price_desc") { <option value="price_desc" selected>Giá giảm dần</option> } else { <option value="price_desc">Giá giảm dần</option> }
                    @if (sortOrder == "name_asc") { <option value="name_asc" selected>Tên A-Z</option> } else { <option value="name_asc">Tên A-Z</option> }
                </select>
            </label>
            <label class="check-line">
                @if (inStock == true)
                {
                    <input type="checkbox" name="inStock" value="true" checked />
                }
                else
                {
                    <input type="checkbox" name="inStock" value="true" />
                }
                <span>Chỉ hiện sản phẩm còn hàng</span>
            </label>
            <button type="submit" class="btn-solid full-width">Áp dụng bộ lọc</button>
        </form>
    </aside>

    <div class="shop-content">
        <div class="shop-toolbar reveal">
            <div>
                <span>@Model.Count() sản phẩm</span>
                <h2>@(string.IsNullOrWhiteSpace(keyword) ? "Selected pieces" : $"Kết quả cho: {keyword}")</h2>
            </div>
            <p>Hình ảnh banner lấy từ nguồn ảnh trực tuyến để tăng cảm giác như một cửa hàng thời trang thực tế.</p>
        </div>

        @if (Model.Any())
        {
            <div class="product-grid shop-grid">
                @foreach (var item in Model)
                {
                    <partial name="~/Views/Shared/_ProductCard.cshtml" model="item" />
                }
            </div>
        }
        else
        {
            <div class="empty-box">
                <h3>Không tìm thấy sản phẩm</h3>
                <p>Thử thay đổi từ khóa, danh mục hoặc khoảng giá.</p>
                <a asp-controller="Product" asp-action="Index" class="btn-solid">Reset bộ lọc</a>
            </div>
        }
    </div>
</section>
