@model CheckoutViewModel
@{
    ViewData["Title"] = "Thanh toán";
}

<section class="page-hero compact cream-hero">
    <div class="container reveal">
        <span>Checkout</span>
        <h1>Secure checkout</h1>
        <p>Nhập thông tin nhận hàng, chọn phương thức thanh toán và hoàn tất đơn hàng trong vài bước ngắn gọn.</p>
    </div>
</section>

<section class="container checkout-layout">
    <div class="form-card reveal">
        <div class="form-title">
            <h2>Thông tin giao hàng</h2>
            <p>Kiểm tra kỹ số điện thoại và địa chỉ để đơn hàng được giao chính xác.</p>
        </div>
        <form asp-controller="Order" asp-action="Checkout" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="field"><label asp-for="HoTenNguoiNhan">Người nhận</label><input asp-for="HoTenNguoiNhan" placeholder="Họ tên người nhận" /><span asp-validation-for="HoTenNguoiNhan" class="text-danger"></span></div>
            <div class="field"><label asp-for="SoDienThoai">Số điện thoại</label><input asp-for="SoDienThoai" placeholder="Số điện thoại" /><span asp-validation-for="SoDienThoai" class="text-danger"></span></div>
            <div class="field"><label asp-for="DiaChiGiaoHang">Địa chỉ</label><textarea asp-for="DiaChiGiaoHang" rows="4" placeholder="Số nhà, đường, phường/xã, quận/huyện, tỉnh/thành"></textarea><span asp-validation-for="DiaChiGiaoHang" class="text-danger"></span></div>
            <div class="field"><label asp-for="PhuongThucThanhToan">Thanh toán</label><select asp-for="PhuongThucThanhToan"><option value="COD">Thanh toán khi nhận hàng</option><option value="Bank">Chuyển khoản ngân hàng</option><option value="Momo">Ví MoMo</option></select><span asp-validation-for="PhuongThucThanhToan" class="text-danger"></span></div>
            <div class="field"><label asp-for="GhiChu">Ghi chú</label><textarea asp-for="GhiChu" rows="3" placeholder="Ví dụ: giao giờ hành chính hoặc gọi trước khi giao"></textarea><span asp-validation-for="GhiChu" class="text-danger"></span></div>
            <button type="submit" class="btn-solid full-width">Đặt hàng ngay</button>
        </form>
    </div>

    <aside class="summary-card checkout-summary reveal delay-1">
        <h2>Order summary</h2>
        @foreach (var item in Model.CartItems)
        {
            <div class="summary-line product-line">
                <span>@item.TenSanPham x @item.SoLuong</span>
                <strong>@item.ThanhTien.ToString("N0") đ</strong>
            </div>
        }
        <div class="summary-total"><span>Tổng tiền</span><strong>@Model.TongTien.ToString("N0") đ</strong></div>
        <div class="mini-policy">
            <p>✓ Đơn sẽ ở trạng thái <strong>Chờ xác nhận</strong> sau khi đặt.</p>
            <p>✓ Hệ thống tự trừ kho khi đơn hàng thành công.</p>
            <p>✓ Theo dõi trạng thái trong mục <strong>Đơn hàng của tôi</strong>.</p>
        </div>
    </aside>
</section>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
