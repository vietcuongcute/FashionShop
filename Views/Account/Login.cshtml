@model FashionShop.Web.Models.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Đăng nhập";
}

<section class="auth-page">
    <div class="auth-card">
        <div class="auth-header">
            <h1>Đăng nhập</h1>
            <p>Chào mừng bạn quay lại Fashion Shop</p>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">
                @TempData["Success"]
            </div>
        }

        <form asp-controller="Account" asp-action="Login" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group-custom">
                <label asp-for="Email">Email</label>
                <input asp-for="Email" placeholder="Nhập email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group-custom">
                <label asp-for="MatKhau">Mật khẩu</label>
                <input asp-for="MatKhau" type="password" placeholder="Nhập mật khẩu" />
                <span asp-validation-for="MatKhau" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-auth">
                Đăng nhập
            </button>
        </form>

        <div class="auth-demo-box">
            <strong>Tài khoản mẫu:</strong>
            <p>Customer: tự đăng ký tài khoản mới để test</p>
            <p>Admin: admin@gmail.com / 123456</p>
        </div>

        <div class="auth-footer">
            Chưa có tài khoản?
            <a asp-controller="Account" asp-action="Register">Đăng ký ngay</a>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}