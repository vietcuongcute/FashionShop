@model FashionShop.Web.Models.Entities.DanhMuc

@{
    ViewData["Title"] = "Thêm danh mục";
}

<div class="admin-page-header">
    <div>
        <h2>Thêm danh mục</h2>
        <p>Tạo danh mục mới cho sản phẩm thời trang.</p>
    </div>

    <a asp-area="Admin" asp-controller="Category" asp-action="Index" class="btn btn-secondary">
        Quay lại
    </a>
</div>

<div class="admin-card form-card">
    <form asp-area="Admin" asp-controller="Category" asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="form-group">
            <label asp-for="TenDanhMuc">Tên danh mục</label>
            <input asp-for="TenDanhMuc" class="form-control" placeholder="Ví dụ: Áo thun" />
            <span asp-validation-for="TenDanhMuc" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="MoTa">Mô tả</label>
            <textarea asp-for="MoTa" class="form-control" rows="4"
                      placeholder="Nhập mô tả ngắn cho danh mục"></textarea>
            <span asp-validation-for="MoTa" class="text-danger"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">
                Lưu danh mục
            </button>

            <a asp-area="Admin" asp-controller="Category" asp-action="Index" class="btn btn-secondary">
                Hủy
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}