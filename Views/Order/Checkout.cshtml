@model FashionShop.Web.Models.ViewModels.CheckoutViewModel

@{
    ViewData["Title"] = "Thanh toán";
}

<section class="page-header">
    <h1>Thanh toán</h1>
    <p>Nhập thông tin giao hàng để hoàn tất đơn hàng</p>
</section>

<form asp-controller="Order" asp-action="Checkout" method="post">
    @Html.AntiForgeryToken()

    <section class="checkout-page">
        <div class="checkout-form-box">
            <h2>Thông tin giao hàng</h2>

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group-custom">
                <label asp-for="HoTenNguoiNhan">Họ tên người nhận</label>
                <input asp-for="HoTenNguoiNhan" placeholder="Nhập họ tên người nhận" />
                <span asp-validation-for="HoTenNguoiNhan" class="text-danger"></span>
            </div>

            <div class="form-group-custom">
                <label asp-for="SoDienThoai">Số điện thoại</label>
                <input asp-for="SoDienThoai" placeholder="Nhập số điện thoại" />
                <span asp-validation-for="SoDienThoai" class="text-danger"></span>
            </div>

            <div class="form-group-custom">
                <label asp-for="DiaChiGiaoHang">Địa chỉ giao hàng</label>
                <textarea asp-for="DiaChiGiaoHang" rows="4" placeholder="Nhập địa chỉ giao hàng"></textarea>
                <span asp-validation-for="DiaChiGiaoHang" class="text-danger"></span>
            </div>

            <div class="form-group-custom">
                <label asp-for="GhiChu">Ghi chú</label>
                <textarea asp-for="GhiChu" rows="3" placeholder="Ghi chú thêm cho đơn hàng nếu có"></textarea>
            </div>
        </div>

        <aside class="checkout-summary">
            <h2>Đơn hàng của bạn</h2>

            @foreach (var item in Model.CartItems)
            {
                <div class="checkout-item">
                    <div>
                        <strong>@item.TenSanPham</strong>
                        <p>Số lượng: @item.SoLuong</p>
                    </div>

                    <span>@item.ThanhTien.ToString("N0") đ</span>
                </div>
            }

            <hr />

            <div class="summary-total">
                <span>Tổng thanh toán</span>
                <strong>@Model.TongTien.ToString("N0") đ</strong>
            </div>

            <button type="submit" class="btn-place-order">
                Xác nhận đặt hàng
            </button>

            <a asp-controller="Cart" asp-action="Index" class="continue-shopping">
                ← Quay lại giỏ hàng
            </a>
        </aside>
    </section>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}