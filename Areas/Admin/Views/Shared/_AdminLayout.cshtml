@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin VyAnhFashion</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="admin-body">
    <div class="admin-shell">
        <aside class="admin-sidebar">
            <div class="admin-brand">
                <div class="admin-logo">VA</div>
                <div>
                    <strong>VyAnhFashion</strong>
                    <span>Admin Center</span>
                </div>
            </div>
            <nav class="admin-nav">
                <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                <a asp-area="Admin" asp-controller="Product" asp-action="Index">Sản phẩm</a>
                <a asp-area="Admin" asp-controller="Category" asp-action="Index">Danh mục</a>
                <a asp-area="Admin" asp-controller="Order" asp-action="Index">Đơn hàng</a>
                <a asp-area="Admin" asp-controller="Customer" asp-action="Index">Khách hàng</a>
                <a asp-area="" asp-controller="Home" asp-action="Index">Xem website</a>
            </nav>
            <div class="admin-private-note">Admin quản lý sản phẩm, đơn hàng, khách hàng. Wishlist là dữ liệu riêng của người mua nên không hiển thị trong admin.</div>
        </aside>
        <main class="admin-main">
            <header class="admin-topbar">
                <div>
                    <span>VyAnhFashion Management</span>
                    <h1>@ViewData["Title"]</h1>
                    <p>Xin chào, @Context.Session.GetString("UserName")</p>
                </div>
                <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="admin-logout">Đăng xuất</button>
                </form>
            </header>
            <section class="admin-content">
                @RenderBody()
            </section>
        </main>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
