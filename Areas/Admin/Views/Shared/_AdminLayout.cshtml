@using Microsoft.AspNetCore.Http

<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Admin Fashion Shop</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body class="admin-body">
    <div class="admin-wrapper">
        <aside class="admin-sidebar">
            <div class="admin-brand">
                <div class="admin-logo">FS</div>
                <div>
                    <strong>Fashion Shop</strong>
                    <span>Admin Panel</span>
                </div>
            </div>

            <nav class="admin-menu">
                <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                    Dashboard
                </a>

                <a asp-area="Admin" asp-controller="Product" asp-action="Index">
                    Quản lý sản phẩm
                </a>

                <a asp-area="Admin" asp-controller="Category" asp-action="Index">
                    Quản lý danh mục
                </a>

                <a asp-area="Admin" asp-controller="Order" asp-action="Index">
                    Quản lý đơn hàng
                </a>

                <a asp-area="" asp-controller="Home" asp-action="Index">
                    Về website
                </a>
            </nav>
        </aside>

        <main class="admin-main">
            <header class="admin-topbar">
                <div>
                    <h1>@ViewData["Title"]</h1>
                    <p>Xin chào, @Context.Session.GetString("UserName")</p>
                </div>

                <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="admin-logout-btn">
                        Đăng xuất
                    </button>
                </form>
            </header>

            <section class="admin-content">
                @RenderBody()
            </section>
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>