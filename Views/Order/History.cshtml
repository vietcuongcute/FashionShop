@model List<DonHang>
@{
    ViewData["Title"] = "Đơn hàng của tôi";
}

<section class="page-hero compact">
    <div class="container">
        <span>Order history</span>
        <h1>Đơn hàng của tôi</h1>
        <p>Theo dõi trạng thái và xem chi tiết các đơn hàng đã đặt tại VyAnhFashion.</p>
    </div>
</section>

<section class="container order-list-page">
    @if (Model.Any())
    {
        <div class="order-list">
            @foreach (var item in Model)
            {
                <article class="order-card">
                    <div>
                        <span class="status-pill @GetStatusClass(item.TrangThai)">@item.TrangThai</span>
                        <h3>Đơn hàng #@item.Id</h3>
                        <p>@item.NgayDat.ToString("dd/MM/yyyy HH:mm") · @item.ChiTietDonHangs.Count sản phẩm</p>
                    </div>
                    <div class="order-card-side">
                        <strong>@item.TongTien.ToString("N0") đ</strong>
                        <a asp-controller="Order" asp-action="Details" asp-route-id="@item.Id" class="btn-soft">Chi tiết</a>
                    </div>
                </article>
            }
        </div>
    }
    else
    {
        <div class="empty-box full">
            <h3>Bạn chưa có đơn hàng</h3>
            <p>Bắt đầu mua sắm để tạo đơn hàng đầu tiên.</p>
            <a asp-controller="Product" asp-action="Index" class="btn-solid">Mua sắm ngay</a>
        </div>
    }
</section>

@functions {
    string GetStatusClass(string trangThai) => trangThai switch
    {
        "Chờ xác nhận" => "pending",
        "Đã xác nhận" => "confirmed",
        "Đang giao" => "shipping",
        "Hoàn thành" => "completed",
        "Đã hủy" => "cancelled",
        _ => "default"
    };
}
