@model FashionShop.Web.Models.Entities.SanPham

@{
    ViewData["Title"] = "Thêm sản phẩm";
}

<div class="admin-page-header">
    <div>
        <h2>Thêm sản phẩm</h2>
        <p>Tạo sản phẩm thời trang mới cho cửa hàng.</p>
    </div>

    <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-secondary">
        Quay lại
    </a>
</div>

<div class="admin-card form-card">
    <form asp-area="Admin" asp-controller="Product" asp-action="Create" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="form-group">
            <label asp-for="TenSanPham">Tên sản phẩm</label>
            <input asp-for="TenSanPham" class="form-control" placeholder="Ví dụ: Áo thun oversize trắng" />
            <span asp-validation-for="TenSanPham" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="DanhMucId">Danh mục</label>
            <select asp-for="DanhMucId" class="form-control" asp-items="ViewBag.DanhMucs">
                <option value="">-- Chọn danh mục --</option>
            </select>
            <span asp-validation-for="DanhMucId" class="text-danger"></span>
        </div>

        <div class="form-row-2">
            <div class="form-group">
                <label asp-for="Gia">Giá bán</label>
                <input asp-for="Gia" class="form-control" type="number" min="0" step="1000" placeholder="150000" />
                <span asp-validation-for="Gia" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="SoLuongTon">Số lượng tồn</label>
                <input asp-for="SoLuongTon" class="form-control" type="number" min="0" placeholder="50" />
                <span asp-validation-for="SoLuongTon" class="text-danger"></span>
            </div>
        </div>

        <div class="form-group">
            <label>Ảnh sản phẩm</label>
            <input type="file" name="imageFile" class="form-control" accept="image/*" />
            <span asp-validation-for="HinhAnh" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="MoTa">Mô tả</label>
            <textarea asp-for="MoTa" class="form-control" rows="5" placeholder="Nhập mô tả sản phẩm..."></textarea>
            <span asp-validation-for="MoTa" class="text-danger"></span>
        </div>

        <div class="form-check-custom">
            <input asp-for="NoiBat" />
            <label asp-for="NoiBat">Hiển thị sản phẩm nổi bật</label>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">
                Lưu sản phẩm
            </button>

            <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-secondary">
                Hủy
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}