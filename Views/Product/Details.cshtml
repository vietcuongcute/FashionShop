@model SanPham
@{
    ViewData["Title"] = Model.TenSanPham;
    var sanPhamLienQuan = ViewBag.SanPhamLienQuan as List<SanPham> ?? new List<SanPham>();
    var returnUrl = Context.Request.Path.ToString() + Context.Request.QueryString.ToString();
    var imageUrl = FashionImageHelper.GetProductImage(Model.HinhAnh, Model.TenSanPham, Model.DanhMuc?.TenDanhMuc);
}

<section class="container product-detail-layout product-detail-refined">
    <div class="detail-gallery reveal">
        <img src="@imageUrl" alt="@Model.TenSanPham" />
    </div>

    <div class="detail-info reveal delay-1">
        <a class="back-link" asp-controller="Product" asp-action="Index">← Quay lại cửa hàng</a>
        <span class="detail-category">@(Model.DanhMuc?.TenDanhMuc ?? "VyAnhFashion")</span>
        <h1>@Model.TenSanPham</h1>
        <div class="detail-price">@Model.Gia.ToString("N0") đ</div>
        <p class="detail-description">@(string.IsNullOrWhiteSpace(Model.MoTa) ? "Thiết kế được chọn theo tinh thần tối giản, dễ phối và phù hợp với tủ đồ hiện đại." : Model.MoTa)</p>

        <div class="detail-option-grid">
            <div><span>Trạng thái</span><strong>@(Model.SoLuongTon > 0 ? "Còn hàng" : "Hết hàng")</strong></div>
            <div><span>Tồn kho</span><strong>@Model.SoLuongTon sản phẩm</strong></div>
            <div><span>Đổi trả</span><strong>7 ngày</strong></div>
            <div><span>Thanh toán</span><strong>COD / Bank / MoMo</strong></div>
        </div>

        <div class="detail-highlight-box">
            <div>
                <strong>Fabric note</strong>
                <span>Ưu tiên form đẹp, dễ mặc và chụp hình.</span>
            </div>
            <div>
                <strong>Styling tip</strong>
                <span>Mix cùng blazer, túi mini hoặc quần suông để lên set hoàn chỉnh.</span>
            </div>
        </div>

        @if (Model.SoLuongTon > 0)
        {
            <form asp-controller="Cart" asp-action="AddToCart" method="post" class="detail-buy-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="sanPhamId" value="@Model.Id" />
                <input type="hidden" name="returnUrl" value="@returnUrl" />
                <label>Số lượng <input type="number" name="soLuong" value="1" min="1" max="@Model.SoLuongTon" /></label>
                <button type="submit" class="btn-solid">Thêm vào giỏ hàng</button>
            </form>
        }
        else
        {
            <button class="btn-solid" disabled>Hết hàng</button>
        }

        <form asp-controller="Wishlist" asp-action="Toggle" method="post" class="wishlist-detail-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="sanPhamId" value="@Model.Id" />
            <input type="hidden" name="returnUrl" value="@returnUrl" />
            <button type="submit">♡ Lưu vào yêu thích</button>
        </form>

        <div class="detail-service-box">
            <p><strong>Delivery:</strong> Miễn phí giao hàng cho đơn từ 499K và hỗ trợ xác nhận đơn nhanh.</p>
            <p><strong>Experience:</strong> Wishlist là dữ liệu riêng của người dùng; tài khoản admin không thấy được danh sách này.</p>
        </div>
    </div>
</section>

@if (sanPhamLienQuan.Any())
{
    <section class="container section-area">
        <div class="section-title reveal">
            <div>
                <span>Related edit</span>
                <h2>Có thể bạn cũng thích</h2>
            </div>
            <a asp-controller="Product" asp-action="Index">Xem thêm</a>
        </div>
        <div class="product-grid related-grid">
            @foreach (var item in sanPhamLienQuan)
            {
                <partial name="~/Views/Shared/_ProductCard.cshtml" model="item" />
            }
        </div>
    </section>
}
