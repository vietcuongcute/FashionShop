@model DonHang
@{
    ViewData["Title"] = $"Chi tiết đơn hàng #{Model.Id}";
}

<section class="page-hero compact">
    <div class="container">
        <span>Order details</span>
        <h1>Chi tiết đơn hàng #@Model.Id</h1>
        <p>Xem sản phẩm, thông tin giao hàng và trạng thái xử lý.</p>
    </div>
</section>

<section class="container order-detail-page">
    <div class="order-detail-main">
        <div class="detail-card order-head-card">
            <div>
                <span class="status-pill @GetStatusClass(Model.TrangThai)">@Model.TrangThai</span>
                <h2>Đơn hàng #@Model.Id</h2>
                <p>Ngày đặt: @Model.NgayDat.ToString("dd/MM/yyyy HH:mm")</p>
            </div>
            <strong>@Model.TongTien.ToString("N0") đ</strong>
        </div>

        <div class="detail-card">
            <h3>Sản phẩm</h3>
            @foreach (var item in Model.ChiTietDonHangs)
            {
                <div class="order-product-row">
                    <div>
                        <b>@(item.SanPham?.TenSanPham ?? "Sản phẩm")</b>
                        <span>@item.DonGia.ToString("N0") đ x @item.SoLuong</span>
                    </div>
                    <strong>@item.ThanhTien.ToString("N0") đ</strong>
                </div>
            }
        </div>
    </div>

    <aside class="summary-card order-info-card">
        <h2>Thông tin nhận hàng</h2>
        <div><span>Người nhận</span><strong>@Model.HoTenNguoiNhan</strong></div>
        <div><span>Số điện thoại</span><strong>@Model.SoDienThoai</strong></div>
        <div class="block-line"><span>Địa chỉ</span><strong>@Model.DiaChiGiaoHang</strong></div>
        @if (!string.IsNullOrWhiteSpace(Model.GhiChu))
        {
            <div class="block-line"><span>Ghi chú</span><strong>@Model.GhiChu</strong></div>
        }
        <a asp-controller="Order" asp-action="History" class="btn-soft full-width">Quay lại đơn hàng</a>
        @if (Model.TrangThai == "Chờ xác nhận")
        {
            <form asp-controller="Order" asp-action="Cancel" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Bạn chắc chắn muốn hủy đơn hàng này?');">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-danger-line full-width">Hủy đơn hàng</button>
            </form>
        }
    </aside>
</section>

@functions {
    string GetStatusClass(string trangThai) => trangThai switch
    {
        "Chờ xác nhận" => "pending",
        "Đã xác nhận" => "confirmed",
        "Đang giao" => "shipping",
        "Hoàn thành" => "completed",
        "Đã hủy" => "cancelled",
        _ => "default"
    };
}
