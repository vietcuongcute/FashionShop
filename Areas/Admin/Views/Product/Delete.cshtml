@model FashionShop.Web.Models.Entities.SanPham

@{
    ViewData["Title"] = "Xóa sản phẩm";
}

<div class="admin-page-header">
    <div>
        <h2>Xóa sản phẩm</h2>
        <p>Kiểm tra kỹ trước khi xóa sản phẩm khỏi cửa hàng.</p>
    </div>

    <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-secondary">
        Quay lại
    </a>
</div>

<div class="admin-card form-card">
    <div class="delete-warning">
        <h3>Bạn có chắc muốn xóa sản phẩm này?</h3>
        <p>Sản phẩm sau khi xóa sẽ không còn hiển thị trên website.</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.HinhAnh))
    {
        <div class="form-group">
            <img src="@Model.HinhAnh" alt="@Model.TenSanPham" class="preview-product-img" />
        </div>
    }

    <div class="detail-row">
        <strong>Mã sản phẩm:</strong>
        <span>#@Model.Id</span>
    </div>

    <div class="detail-row">
        <strong>Tên sản phẩm:</strong>
        <span>@Model.TenSanPham</span>
    </div>

    <div class="detail-row">
        <strong>Danh mục:</strong>
        <span>@(Model.DanhMuc?.TenDanhMuc ?? "Chưa có")</span>
    </div>

    <div class="detail-row">
        <strong>Giá:</strong>
        <span>@Model.Gia.ToString("N0") đ</span>
    </div>

    <div class="detail-row">
        <strong>Số lượng tồn:</strong>
        <span>@Model.SoLuongTon</span>
    </div>

    <div class="detail-row">
        <strong>Sản phẩm nổi bật:</strong>
        <span>@(Model.NoiBat ? "Có" : "Không")</span>
    </div>

    <form asp-area="Admin" asp-controller="Product" asp-action="DeleteConfirmed" method="post" class="form-actions">
        @Html.AntiForgeryToken()

        <input type="hidden" name="id" value="@Model.Id" />

        <button type="submit" class="btn btn-danger">
            Xác nhận xóa
        </button>

        <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-secondary">
            Hủy
        </a>
    </form>
</div>