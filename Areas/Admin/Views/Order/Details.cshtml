@model FashionShop.Web.Models.Entities.DonHang

@{
    ViewData["Title"] = "Chi tiết đơn hàng";
    var trangThaiList = ViewBag.TrangThaiList as List<string>;
}

<div class="admin-page-header">
    <div>
        <h2>Chi tiết đơn hàng #@Model.Id</h2>
        <p>Xem thông tin giao hàng, sản phẩm và cập nhật trạng thái đơn hàng.</p>
    </div>

    <a asp-area="Admin" asp-controller="Order" asp-action="Index" class="btn btn-secondary">
        Quay lại
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

<div class="order-detail-grid">
    <div class="admin-card">
        <h3 class="section-title">Thông tin đơn hàng</h3>

        <div class="detail-row">
            <strong>Mã đơn:</strong>
            <span>#@Model.Id</span>
        </div>

        <div class="detail-row">
            <strong>Ngày đặt:</strong>
            <span>@Model.NgayDat.ToString("dd/MM/yyyy HH:mm")</span>
        </div>

        <div class="detail-row">
            <strong>Trạng thái hiện tại:</strong>
            <span class="order-status @GetStatusClass(Model.TrangThai)">
                @Model.TrangThai
            </span>
        </div>

        <div class="detail-row">
            <strong>Tổng tiền:</strong>
            <span class="money-text">@Model.TongTien.ToString("N0") đ</span>
        </div>

        <div class="detail-row">
            <strong>Ghi chú:</strong>
            <span>
                @if (!string.IsNullOrWhiteSpace(Model.GhiChu))
                {
                    @Model.GhiChu
                }
                else
                {
                    <span class="text-muted">Không có ghi chú</span>
                }
            </span>
        </div>
    </div>

    <div class="admin-card">
        <h3 class="section-title">Cập nhật trạng thái</h3>

        <form asp-area="Admin" asp-controller="Order" asp-action="UpdateStatus" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" name="id" value="@Model.Id" />

            <div class="form-group">
                <label>Trạng thái đơn hàng</label>
                <select name="trangThai" class="form-control">
                    @if (trangThaiList != null)
                    {
                        foreach (var item in trangThaiList)
                        {
                            if (Model.TrangThai == item)
                            {
                                <option value="@item" selected>@item</option>
                            }
                            else
                            {
                                <option value="@item">@item</option>
                            }
                        }
                    }
                </select>
            </div>

            <button type="submit" class="btn btn-primary">
                Cập nhật trạng thái
            </button>
        </form>
    </div>
</div>

<div class="order-detail-grid" style="margin-top: 20px;">
    <div class="admin-card">
        <h3 class="section-title">Thông tin khách hàng</h3>

        <div class="detail-row">
            <strong>Tài khoản đặt:</strong>
            <span>
                @if (Model.NguoiDung != null)
                {
                    @Model.NguoiDung.HoTen
                    <span class="text-muted">(@Model.NguoiDung.Email)</span>
                }
                else
                {
                    <span class="text-muted">Khách vãng lai</span>
                }
            </span>
        </div>

        <div class="detail-row">
            <strong>Người nhận:</strong>
            <span>@Model.HoTenNguoiNhan</span>
        </div>

        <div class="detail-row">
            <strong>Số điện thoại:</strong>
            <span>@Model.SoDienThoai</span>
        </div>

        <div class="detail-row">
            <strong>Địa chỉ giao hàng:</strong>
            <span>@Model.DiaChiGiaoHang</span>
        </div>
    </div>
</div>

<div class="admin-card" style="margin-top: 20px;">
    <h3 class="section-title">Sản phẩm trong đơn</h3>

    @if (Model.ChiTietDonHangs != null && Model.ChiTietDonHangs.Any())
    {
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Ảnh</th>
                    <th>Sản phẩm</th>
                    <th>Đơn giá</th>
                    <th>Số lượng</th>
                    <th>Thành tiền</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model.ChiTietDonHangs)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(item.SanPham?.HinhAnh))
                            {
                                <img src="@item.SanPham.HinhAnh" alt="@item.SanPham.TenSanPham" class="admin-product-img" />
                            }
                            else
                            {
                                <div class="admin-product-img no-image">
                                    No image
                                </div>
                            }
                        </td>

                        <td>
                            <strong>@(item.SanPham?.TenSanPham ?? "Sản phẩm đã xóa")</strong>
                            <div class="text-muted">Mã sản phẩm: #@item.SanPhamId</div>
                        </td>

                        <td>@item.DonGia.ToString("N0") đ</td>

                        <td>@item.SoLuong</td>

                        <td>
                            <strong>@item.ThanhTien.ToString("N0") đ</strong>
                        </td>
                    </tr>
                }
            </tbody>

            <tfoot>
                <tr>
                    <td colspan="4" style="text-align: right;">
                        <strong>Tổng cộng:</strong>
                    </td>
                    <td>
                        <strong class="money-text">@Model.TongTien.ToString("N0") đ</strong>
                    </td>
                </tr>
            </tfoot>
        </table>
    }
    else
    {
        <div class="empty-box">
            Đơn hàng này chưa có sản phẩm.
        </div>
    }
</div>

@functions {
    string GetStatusClass(string trangThai)
    {
        return trangThai switch
        {
            "Chờ xác nhận" => "status-pending",
            "Đã xác nhận" => "status-confirmed",
            "Đang giao" => "status-shipping",
            "Hoàn thành" => "status-completed",
            "Đã hủy" => "status-cancelled",
            _ => "status-default"
        };
    }
}