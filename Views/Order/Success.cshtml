@model DonHang
@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<section class="success-page">
    <div class="success-card">
        <div class="success-mark">✓</div>
        <span>Order placed</span>
        <h1>Đặt hàng thành công</h1>
        <p>Cảm ơn bạn đã mua hàng tại VyAnhFashion. Đơn hàng đang chờ xác nhận.</p>
        <div class="success-grid">
            <div><span>Mã đơn</span><strong>#@Model.Id</strong></div>
            <div><span>Ngày đặt</span><strong>@Model.NgayDat.ToString("dd/MM/yyyy HH:mm")</strong></div>
            <div><span>Trạng thái</span><strong>@Model.TrangThai</strong></div>
            <div><span>Tổng tiền</span><strong>@Model.TongTien.ToString("N0") đ</strong></div>
        </div>
        <div class="success-actions">
            <a asp-controller="Order" asp-action="Details" asp-route-id="@Model.Id" class="btn-solid">Xem đơn hàng</a>
            <a asp-controller="Product" asp-action="Index" class="btn-soft">Tiếp tục mua sắm</a>
        </div>
    </div>
</section>
