@model LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<section class="auth-layout refined-auth">
    <div class="auth-panel visual reveal" style="background-image:linear-gradient(180deg, rgba(22,20,20,.18), rgba(22,20,20,.68)), url('@FashionImageHelper.GetLookbook("login")')">
        <div class="visual-copy">
            <span>Welcome back</span>
            <h1>Sign in to your fashion space.</h1>
            <p>Lưu wishlist, theo dõi đơn hàng và checkout nhanh hơn trong những lần mua tiếp theo.</p>
        </div>
    </div>
    <div class="auth-panel form-panel reveal delay-1">
        <div class="form-title">
            <span class="eyebrow">Account</span>
            <h2>Đăng nhập</h2>
            <p>Nhập email và mật khẩu để truy cập tài khoản VyAnhFashion.</p>
        </div>
        <form asp-controller="Account" asp-action="Login" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="field"><label asp-for="Email">Email</label><input asp-for="Email" placeholder="you@example.com" /><span asp-validation-for="Email" class="text-danger"></span></div>
            <div class="field"><label asp-for="MatKhau">Mật khẩu</label><input asp-for="MatKhau" type="password" placeholder="••••••••" /><span asp-validation-for="MatKhau" class="text-danger"></span></div>
            <button type="submit" class="btn-solid full-width">Đăng nhập</button>
        </form>
        <p class="form-note">Chưa có tài khoản? <a asp-controller="Account" asp-action="Register">Tạo tài khoản mới</a></p>
    </div>
</section>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
