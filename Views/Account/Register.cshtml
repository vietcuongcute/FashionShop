@model FashionShop.Web.Models.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Đăng ký";
}

<section class="auth-page">
    <div class="auth-card">
        <div class="auth-header">
            <h1>Tạo tài khoản</h1>
            <p>Đăng ký để mua sắm và theo dõi đơn hàng của bạn</p>
        </div>

        <form asp-controller="Account" asp-action="Register" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group-custom">
                <label asp-for="HoTen">Họ tên</label>
                <input asp-for="HoTen" placeholder="Nhập họ tên của bạn" />
                <span asp-validation-for="HoTen" class="text-danger"></span>
            </div>

            <div class="form-group-custom">
                <label asp-for="Email">Email</label>
                <input asp-for="Email" placeholder="Nhập email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group-custom">
                <label asp-for="MatKhau">Mật khẩu</label>
                <input asp-for="MatKhau" type="password" placeholder="Nhập mật khẩu" />
                <span asp-validation-for="MatKhau" class="text-danger"></span>
            </div>

            <div class="form-group-custom">
                <label asp-for="XacNhanMatKhau">Xác nhận mật khẩu</label>
                <input asp-for="XacNhanMatKhau" type="password" placeholder="Nhập lại mật khẩu" />
                <span asp-validation-for="XacNhanMatKhau" class="text-danger"></span>
            </div>

            <div class="form-group-custom">
                <label asp-for="SoDienThoai">Số điện thoại</label>
                <input asp-for="SoDienThoai" placeholder="Nhập số điện thoại" />
                <span asp-validation-for="SoDienThoai" class="text-danger"></span>
            </div>

            <div class="form-group-custom">
                <label asp-for="DiaChi">Địa chỉ</label>
                <textarea asp-for="DiaChi" rows="3" placeholder="Nhập địa chỉ"></textarea>
                <span asp-validation-for="DiaChi" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-auth">
                Đăng ký
            </button>
        </form>

        <div class="auth-footer">
            Đã có tài khoản?
            <a asp-controller="Account" asp-action="Login">Đăng nhập ngay</a>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}