@model List<CartItemViewModel>
@{
    ViewData["Title"] = "Giỏ hàng";
    var total = Model.Sum(x => x.ThanhTien);
    var shipping = total >= 499000 || total == 0 ? 0 : 30000;
}

<section class="page-hero compact cream-hero">
    <div class="container reveal">
        <span>Shopping bag</span>
        <h1>Your shopping bag</h1>
        <p>Xem lại sản phẩm đã chọn, số lượng, ưu đãi giao hàng và tổng thanh toán trước khi tiếp tục checkout.</p>
    </div>
</section>

<section class="container cart-layout">
    @if (Model.Any())
    {
        <div class="cart-list reveal">
            @foreach (var item in Model)
            {
                var imageUrl = FashionImageHelper.GetProductImage(item.HinhAnh, item.TenSanPham);
                <article class="cart-item">
                    <div class="cart-product">
                        <img src="@imageUrl" alt="@item.TenSanPham" />
                        <div>
                            <h3>@item.TenSanPham</h3>
                            <p>@item.Gia.ToString("N0") đ</p>
                            <small>Còn @item.SoLuongTon sản phẩm</small>
                        </div>
                    </div>
                    <div class="cart-actions">
                        <form asp-controller="Cart" asp-action="UpdateQuantity" method="post" class="qty-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="sanPhamId" value="@item.SanPhamId" />
                            <input type="number" name="soLuong" value="@item.SoLuong" min="0" max="@item.SoLuongTon" />
                            <button type="submit" class="btn-soft">Cập nhật</button>
                        </form>
                        <strong>@item.ThanhTien.ToString("N0") đ</strong>
                        <form asp-controller="Cart" asp-action="Remove" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="sanPhamId" value="@item.SanPhamId" />
                            <button type="submit" class="remove-link">Xóa</button>
                        </form>
                    </div>
                </article>
            }
        </div>

        <aside class="summary-card reveal delay-1">
            <h2>Order summary</h2>
            <div class="summary-line"><span>Tạm tính</span><strong>@total.ToString("N0") đ</strong></div>
            <div class="summary-line"><span>Phí vận chuyển</span><strong>@(shipping == 0 ? "Miễn phí" : shipping.ToString("N0") + " đ")</strong></div>
            <div class="summary-total"><span>Tổng thanh toán</span><strong>@((total + shipping).ToString("N0")) đ</strong></div>
            <a asp-controller="Order" asp-action="Checkout" class="btn-solid full-width">Tiến hành thanh toán</a>
            <a asp-controller="Product" asp-action="Index" class="btn-outline-dark full-width">Tiếp tục mua sắm</a>
            <div class="mini-policy">
                <p>✓ Freeship cho đơn từ 499K</p>
                <p>✓ Hỗ trợ đổi trả trong 7 ngày</p>
                <p>✓ Quy trình thanh toán bảo mật, nhanh gọn</p>
            </div>
        </aside>
    }
    else
    {
        <div class="empty-box full reveal">
            <h3>Giỏ hàng của bạn đang trống</h3>
            <p>Thêm vài món thật đẹp để bắt đầu đơn hàng đầu tiên.</p>
            <a asp-controller="Product" asp-action="Index" class="btn-solid">Khám phá sản phẩm</a>
        </div>
    }
</section>
