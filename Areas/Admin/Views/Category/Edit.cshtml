@model FashionShop.Web.Models.Entities.DanhMuc

@{
    ViewData["Title"] = "Sửa danh mục";
}

<div class="admin-page-header">
    <div>
        <h2>Sửa danh mục</h2>
        <p>Cập nhật thông tin danh mục sản phẩm.</p>
    </div>

    <a asp-area="Admin" asp-controller="Category" asp-action="Index" class="btn btn-secondary">
        Quay lại
    </a>
</div>

<div class="admin-card form-card">
    <form asp-area="Admin" asp-controller="Category" asp-action="Edit" method="post">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="Id" />

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="form-group">
            <label asp-for="TenDanhMuc">Tên danh mục</label>
            <input asp-for="TenDanhMuc" class="form-control" />
            <span asp-validation-for="TenDanhMuc" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="MoTa">Mô tả</label>
            <textarea asp-for="MoTa" class="form-control" rows="4"></textarea>
            <span asp-validation-for="MoTa" class="text-danger"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">
                Cập nhật
            </button>

            <a asp-area="Admin" asp-controller="Category" asp-action="Index" class="btn btn-secondary">
                Hủy
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}