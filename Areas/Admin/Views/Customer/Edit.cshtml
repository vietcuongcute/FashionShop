@model FashionShop.Web.Models.Entities.NguoiDung

@{
    ViewData["Title"] = "Cập nhật khách hàng";
}

<div class="admin-card">
    <div class="admin-card-header">
        <div>
            <h2>Cập nhật khách hàng</h2>
            <p>Chỉnh sửa thông tin tài khoản khách hàng.</p>
        </div>

        <a asp-action="Index" class="btn-admin-light">Quay lại</a>
    </div>

    <form asp-action="Edit" method="post" class="admin-form">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="VaiTro" />

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="form-group">
            <label asp-for="HoTen">Họ tên</label>
            <input asp-for="HoTen" />
            <span asp-validation-for="HoTen" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Email">Email</label>
            <input asp-for="Email" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="SoDienThoai">Số điện thoại</label>
            <input asp-for="SoDienThoai" />
            <span asp-validation-for="SoDienThoai" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="DiaChi">Địa chỉ</label>
            <textarea asp-for="DiaChi" rows="3"></textarea>
            <span asp-validation-for="DiaChi" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="MatKhau">Mật khẩu mới</label>
            <input asp-for="MatKhau" value="" placeholder="Bỏ trống nếu không muốn đổi mật khẩu" />
            <span asp-validation-for="MatKhau" class="text-danger"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-admin-primary">Lưu thay đổi</button>
            <a asp-action="Index" class="btn-admin-light">Hủy</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}